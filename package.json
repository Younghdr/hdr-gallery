{
  "name": "young-hung-hdr-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/prepare-public-assets.js",
    "dev": "cross-env NEXT_DIST_DIR=.next-dev next dev",
    "prebuild": "node scripts/prepare-public-assets.js",
    "build": "cross-env NEXT_DIST_DIR=.next-build next build",
    "prebuild:github": "node scripts/prepare-public-assets.js",
    "build:github": "cross-env GITHUB_PAGES=1 NEXT_PUBLIC_BASE_PATH=/hdr-gallery NEXT_DIST_DIR=.next-github next build",
    "start": "next start",
    "lint": "tsc --noEmit --pretty false --incremental false"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "framer-motion": "^12.23.12",
    "next": "^15.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  }
}
